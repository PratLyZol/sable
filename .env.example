# ── Copilot chat (pick ONE) ─────────────────────────────────────────
# The copilot dock needs one of these. AI Gateway is recommended.
AI_GATEWAY_API_KEY=
# ANTHROPIC_API_KEY=

# ── Chain mode ──────────────────────────────────────────────────────
# Leave unset (or "sim") for the in-memory rail. Set to "devnet" after
# running `npm run devnet:setup` to settle on Solana devnet for real.
# SABLE_MODE=devnet

# ── Pay to email / claim flow ───────────────────────────────────────
# Absolute base URL used to build claim links and the QR codes embedded
# in claim emails. Defaults to http://localhost:3000. For phone-scan
# demos, set this to your machine's LAN IP and start the dev server with
# `next dev -H 0.0.0.0` so a phone on the same network can reach it:
#   SABLE_PUBLIC_URL=http://192.168.1.42:3000
# SABLE_PUBLIC_URL=

# Optional: real email delivery via SMTP. Claim emails ALWAYS land in the
# in-app Outbox (/outbox); with SMTP configured they are ALSO really sent.
# Gmail + app password is the easy path (delivers to ANY address):
# 1. Enable 2-step verification on your Google account
# 2. Create an app password: https://myaccount.google.com/apppasswords
# 3. Fill these in (host/port default to Gmail; any SMTP provider works,
#    e.g. Outlook: SABLE_SMTP_HOST=smtp-mail.outlook.com SABLE_SMTP_PORT=587)
# SABLE_SMTP_USER=you@gmail.com
# SABLE_SMTP_PASS=abcd efgh ijkl mnop
# SABLE_SMTP_HOST=smtp.gmail.com
# SABLE_SMTP_PORT=465

# Optional: the From address for claim emails. Defaults to the SMTP user.
# SABLE_EMAIL_FROM=Sable <you@gmail.com>
