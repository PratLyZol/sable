# ── Copilot chat (pick ONE) ─────────────────────────────────────────
# The copilot dock needs one of these. AI Gateway is recommended.
AI_GATEWAY_API_KEY=
# ANTHROPIC_API_KEY=

# ── Chain mode ──────────────────────────────────────────────────────
# Leave unset (or "sim") for the in-memory rail. Set to "devnet" after
# running `npm run devnet:setup` to settle on Solana devnet for real.
# SABLE_MODE=devnet

# ── Pay to email / claim flow ───────────────────────────────────────
# Absolute base URL used to build claim links and the QR codes embedded
# in claim emails. Defaults to http://localhost:3000. For phone-scan
# demos, set this to your machine's LAN IP and start the dev server with
# `next dev -H 0.0.0.0` so a phone on the same network can reach it:
#   SABLE_PUBLIC_URL=http://192.168.1.42:3000
# SABLE_PUBLIC_URL=

# Optional: real email delivery via Resend. Without a key, every claim
# email is written to the in-app Outbox (/outbox) instead of being sent.
# Note: the shared onboarding@resend.dev sender only delivers to the
# email on the Resend account that owns the key — verify your own domain
# to send to arbitrary recipients.
# RESEND_API_KEY=

# Optional: the From address for claim emails (needs a verified domain).
# Defaults to onboarding@resend.dev.
# SABLE_EMAIL_FROM=payments@yourdomain.com
